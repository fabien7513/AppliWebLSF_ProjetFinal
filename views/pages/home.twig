{% extends "../layout/base.twig" %}

{% block style %}
	<link rel="stylesheet" href="/static/assets/css/home.css">
	<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
{% endblock %}

{% block main %}

	<header class="home-header">
		<div class="header-top">
			<div class="logo">
				<img src="/static/assets/images/logo2.png" alt="Logo">
			</div>

			<a href="/login" class="interpreter-btn">
				Vous êtes interprète ?
			</a>
		</div>

		<div class="header-center">
			<button id="open-modal" class="search-btn">
				🔎 Trouvez un interprète LSF en toute simplicité
			</button>

			<a href="/interpreters" class="show-btn">
				Afficher les interprètes
			</a>
		</div>
	</header>

	<main>
		<section class="map-section">
			<div class="map-container">
				<h2 class="map-title">📍 Localisez un interprète près de vous</h2>
				<p class="map-subtitle">
					Cliquez sur un point de la carte pour consulter le profil de l'interprète
				</p>

				<div class="map-wrapper">
					<div id="map"></div>
				</div>
			</div>
		</section>

		<section class="role-section">
			<div class="role-container">
				<h2>Le rôle d’une interprète LSF</h2>

				<ul class="role-list">
					<li>Traduction en temps réel</li>
					<li>Neutralité et confidentialité</li>
					<li>Communication accessible</li>
				</ul>
			</div>
		</section>

		<section class="services-section">
			<h2 class="services-title">Ce que nous proposons</h2>

			<div class="services-container">
				<div class="service-card">
					<img src="/static/assets/images/trad1.png" alt="Interprétation">
					<h3>Interprétation et déontologie</h3>
					<p>
						L’interprète a pour rôle de transmettre un discours d’une langue vers
																																										          une autre. Respect du sens, neutralité et confidentialité.
					</p>
					<ul>
						<li>Secret professionnel</li>
						<li>Fidélité du message</li>
						<li>Neutralité</li>
					</ul>
				</div>

				<div class="service-card">
					<img src="/static/assets/images/trad2.png" alt="Domaines d'interventions">
					<h3>Domaines d'interventions</h3>
					<p>
						Nos interventions couvrent plusieurs domaines professionnels et
																																										          institutionnels.
					</p>
					<ul>
						<li>Institutionnel</li>
						<li>Culturel</li>
						<li>Politique</li>
						<li>Santé</li>
						<li>Sport et loisirs</li>
					</ul>
				</div>

				<div class="service-card">
					<img src="/static/assets/images/trad3.png" alt="Éthique et expertise">
					<h3>Éthique et expertise</h3>
					<p>
						Tous nos interprètes sont diplômés et s'engagent à respecter une
																																										          déontologie professionnelle stricte.
					</p>
				</div>
			</div>
		</section>

		<section class="about-section">
			<div class="about-container">
				<div class="about-logo">
					<img src="/static/assets/images/logo2.png" alt="Logo Réseau LSF">
				</div>

				<div class="about-text">
					<p>
						Réseau LSF Méditerranée facilite la mise en relation entre clients
																																										          et interprètes en Langue des Signes Française.
					</p>

					<p>
						Les interprètes exercent en tant qu’indépendants et gèrent
																																										          directement leurs interventions, disponibilités et modalités
																																										          d’interventions.
					</p>
				</div>
			</div>
		</section>
	</main>


	<div id="search-modal" class="modal hidden">
		<div class="modal-box">
			<button id="close-modal" type="button">x</button>

			<h2 class="modal-title">Trouvez un interprète</h2>

			<form class="modal-form">
				<input type="text" placeholder="Lieu de votre rendez-vous">
				<input type="date">

				<label>Heure début</label>
				<input type="time" id="start-time">

				<label>Heure fin</label>
				<input type="time" id="end-time">

				<label>Durée</label>
				<input type="text" id="duration" readonly placeholder="Calcul automatique">

				<button type="submit" class="modal-submit">Rechercher</button>
			</form>
		</div>
	</div>


	<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

	<script>
		const map = L.map('map').setView([
43.22, 5.48
], 9);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {attribution: '&copy; OpenStreetMap contributors'}).addTo(map);

L.marker([43.2965, 5.3698]).addTo(map).bindPopup('Interprète à Marseille');

L.marker([43.1748, 5.6045]).addTo(map).bindPopup('Interprète à La Ciotat');
	</script>


	{# Modale bouton "Trouvez un interprète" #}
	<script>
		const openModalBtn = document.querySelector('#open-modal');
const closeModalBtn = document.querySelector('#close-modal');
const modal = document.querySelector('#search-modal');
const startTime = document.querySelector("#start-time");
const endTime = document.querySelector("#end-time");
const duration = document.querySelector("#duration");

openModalBtn.addEventListener('click', () => {
modal.classList.remove('hidden');
});

closeModalBtn.addEventListener('click', () => {
modal.classList.add('hidden');
});

modal.addEventListener('click', (event) => {
if (event.target === modal) {
modal.classList.add('hidden');
}
});

function calculateDuration() {

if (startTime.value && endTime.value) {

const start = new Date (`1970-01-01T${
startTime.value
}:00`);
const end = new Date (`1970-01-01T${
endTime.value
}:00`);

const diff = (end - start) / 60000;

if (diff > 0) {
const hours = Math.floor(diff / 60);
const minutes = diff % 60;

duration.value = `${hours}h ${minutes}min`;
} else {
duration.value = "Heure invalide";
}
}
}

startTime.addEventListener("change", calculateDuration);
endTime.addEventListener("change", calculateDuration);
	</script>

{% endblock %}
