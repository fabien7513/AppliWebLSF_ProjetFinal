model User {
    id_user   Int    @id @default(autoincrement())
    lastName  String @db.VarChar(50)
    firstName String @db.VarChar(50)
    mail      String @unique

    description String?
    photo       String?

    password String

    phone       String? @db.VarChar(20)
    siretNumber String @unique @db.VarChar(14) 

    profilStatus String?

    planning_public Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    interventionZones InterventionZone[]
    availabilities    Availability[]

    events Event[]

    addressId Int?
    address   Address? @relation(fields: [addressId], references: [id_address])
}
